{
  "name": "violent-wizards",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A multiplayer social deduction combat game about hidden shield frequencies and magical torpedoes.",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client:delayed\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:client:delayed": "node -e \"setTimeout(() => { require('child_process').spawn('npm', ['run', 'dev:client'], { stdio: 'inherit', shell: true }); }, 1500)\"",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "npm run typecheck && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.build.json",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server-dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "express": "^5.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
